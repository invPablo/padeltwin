{
  "expo": {
    "name": "PadelScrim",
    "slug": "padelscrim",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0C10"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.padelscrim.app"
    },
    "android": {
      "package": "com.padelscrim.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0B0C10"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "PadelScrim uses your location to show players and matches near you."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "PadelScrim uses your photo library to set your profile picture."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#C6FF33"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "891aa7a0-9cd2-40cc-8ca4-25899b831df3"
      }
    },
    "owner": "pablodevelopss-team",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/891aa7a0-9cd2-40cc-8ca4-25899b831df3"
    }
  }
}
